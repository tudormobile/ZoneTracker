  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gen-version": "node scripts/gen-version.js",
    "build": "run-s gen-version type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "deploy:cloudflare": "wrangler deploy --config wrangler.jsonc --assets dist",
    "cf-typegen": "wrangler types",
    "build-only": "vite build",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.101.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
